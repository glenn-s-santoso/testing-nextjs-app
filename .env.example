MYTHOS_API_URL=http://localhost:5001
CALCULATOR_BASE_URL=http://localhost:3001
TEST_USER_EMAIL=carol@example.com
TEST_USER_PASSWORD=Test@1234
# --- written by scripts/bootstrap.ts, do not hand-edit ---
MYTHOS_LISTING_ID=

# Optional: only needed on Vercel (or any multi-instance deploy). Each API
# route is its own isolated function there, so the local-file listing-ids
# store can't share state across routes — set these to use Redis instead.
# Copy from the Upstash integration's "Connect" panel (.env.local tab) in the
# Vercel dashboard's Storage tab (free tier). Unset locally — falls back to
# the file store, no setup needed.
# MYTHOS_LISTING_UPSTASH_KV_REST_API_URL=
# MYTHOS_LISTING_UPSTASH_KV_REST_API_TOKEN=
